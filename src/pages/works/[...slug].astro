---
import Base from '../../layouts/Base.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const works = await getCollection('works', ({ data }) => !data.draft);
  return works.map((work) => ({
    params: { slug: work.id },
    props: { work },
  }));
}

import { asset } from '../../lib/asset';

const { work } = Astro.props;
const { Content } = await render(work);
const siteUrl = Astro.site?.origin ?? 'https://noahberrie.com';

const workImage = work.data.thumbnail || work.data.images[0];
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  "name": work.data.title,
  "creator": {
    "@type": "Person",
    "name": "Noah Berrie",
    "url": siteUrl
  },
  "dateCreated": work.data.year,
  "description": work.data.summary,
  "artMedium": work.data.medium,
  "artform": "Sound Installation",
  "url": `${siteUrl}/works/${work.id}/`,
  ...(workImage && { "image": `${siteUrl}${workImage}` }),
};
---

<Base
  title={work.data.title}
  description={work.data.summary}
  path={`/works/${work.id}/`}
  image={work.data.thumbnail || work.data.images[0]}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />

  <article class="work-detail">
    <!-- Left sidebar: title + meta + counter, fixed in nav column -->
    <div class="work-detail-sidebar">
      <h1 class="work-detail-title">{work.data.title}</h1>
      <div class="work-detail-medium">{work.data.medium}</div>
      <div class="work-detail-year">{work.data.year}</div>
      {work.data.images.length > 1 && (
        <div class="gallery-counter" role="status" aria-live="polite">1 / {work.data.images.length}</div>
      )}
    </div>

    <!-- Right content: gallery + video + text -->
    <div class="work-detail-content">
      {work.data.images.length > 0 ? (
        <div class="work-scroll-wrap" data-image-count={work.data.images.length}>
          <div class="work-scroll-gallery">
            <div class="work-scroll-track">
              {work.data.images.map((img, i) => (
                <img
                  src={asset(img)}
                  alt={i === 0
                    ? `${work.data.title} by Noah Berrie — ${work.data.medium}`
                    : `${work.data.title} — documentation image ${i + 1}`}
                  loading={i === 0 ? "eager" : "lazy"}
                  fetchpriority={i === 0 ? "high" : undefined}
                />
              ))}
            </div>
          </div>
        </div>
      ) : work.data.thumbnail && !work.data.video && work.data.images.length > 0 ? (
        <div class="work-scroll-wrap" data-image-count="1">
          <div class="work-scroll-gallery">
            <div class="work-scroll-track">
              <img
                src={asset(work.data.thumbnail)}
                alt={`${work.data.title} by Noah Berrie — ${work.data.medium}`}
              />
            </div>
          </div>
        </div>
      ) : !work.data.video && !work.data.bandcamp ? (
        <div class="placeholder" style="margin-top: 2rem;">
          Documentation images to be added
        </div>
      ) : null}

      {work.data.audioFile && (
        <AudioPlayer src={work.data.audioFile} title={work.data.title} work={work.data.title} />
      )}
      {work.data.audioNote && (
        <p class="audio-note">{work.data.audioNote}</p>
      )}

      <div class="work-detail-lower">
        <div class="work-detail-body">
          <Content />
          {work.data.scorePdf && (
            <a
              class="work-score-link"
              href={asset(work.data.scorePdf)}
              download
              data-umami-event="score-download"
              data-umami-event-work={work.data.title}
            >
              download score (PDF) ↗
            </a>
          )}
        </div>

        {work.data.audioFiles.length > 0 && (
          <div class="audio-files-block">
            {work.data.audioFiles.map((af, i) => (
              <div class="audio-file-entry">
                <AudioPlayer src={af.src} title={`${work.data.title} — ${i + 1}`} work={work.data.title} clip={String(i + 1)} />
                {af.note && <p class="audio-note">{af.note}</p>}
              </div>
            ))}
          </div>
        )}

        {work.data.video && (
          <VideoEmbed
            url={work.data.video}
            type={work.data.videoType}
            poster={workImage}
            label={`Play ${work.data.title} video`}
            titleAttr={`${work.data.title} — video`}
            workTitle={work.data.title}
          />
        )}

        {work.data.videosBelow.length > 0 && (
          <div class="work-videos-below">
            {work.data.videosBelow.map((v, i) => (
              <VideoEmbed
                url={v.url}
                type={v.type}
                poster={workImage}
                label={`Play ${work.data.title} video ${i + 1}`}
                titleAttr={`${work.data.title} — video ${i + 1}`}
                workTitle={work.data.title}
              />
            ))}
          </div>
        )}

        <script is:inline define:vars={{ workTitle: work.data.title }}>
          function trackVideoWatch(video, work, src) {
            let startedAt = 0;
            let totalMs = 0;
            let fired = false;
            function markPlay() { if (startedAt === 0) startedAt = Date.now(); }
            function markStop() {
              if (startedAt !== 0) {
                totalMs += Date.now() - startedAt;
                startedAt = 0;
              }
            }
            function fire(reason) {
              if (fired) return;
              markStop();
              if (totalMs < 3000) return;
              fired = true;
              const dur = video.duration || 0;
              const seconds = Math.round(totalMs / 1000);
              const pct = dur ? Math.min(100, Math.round((totalMs / 1000 / dur) * 100)) : 0;
              window.umami?.track?.('video-end', { work, src, seconds, pct, reason });
            }
            video.addEventListener('play', markPlay);
            video.addEventListener('pause', markStop);
            video.addEventListener('ended', () => fire('ended'));
            window.addEventListener('pagehide', () => fire('leave'), { once: true });
          }

          document.querySelectorAll('.video-facade').forEach((btn) => {
            btn.addEventListener('click', () => {
              const local = btn.getAttribute('data-local-src');
              const yt = btn.getAttribute('data-yt-src');
              if (local) {
                const v = document.createElement('video');
                v.src = local;
                v.controls = true;
                v.autoplay = true;
                v.playsInline = true;
                v.preload = 'metadata';
                v.title = btn.getAttribute('aria-label') || '';
                btn.replaceWith(v);
                v.play?.().catch(() => {});
                trackVideoWatch(v, workTitle, local);
              } else if (yt) {
                const iframe = document.createElement('iframe');
                iframe.src = yt;
                iframe.setAttribute('allow', 'autoplay; fullscreen; picture-in-picture; gyroscope; accelerometer');
                iframe.setAttribute('allowfullscreen', '');
                iframe.title = btn.getAttribute('aria-label') || '';
                btn.replaceWith(iframe);
              }
            });
          });
        </script>

        {work.data.bandcamp && (
          <div class={`bandcamp-wrap bandcamp-wrap--${work.data.bandcampLayout}`}>
            {work.data.bandcampNote && (
              <p class="bandcamp-note">{work.data.bandcampNote}</p>
            )}
            <div class={`bandcamp-embed bandcamp-embed--${work.data.bandcampLayout}`}>
              <iframe
                src={work.data.bandcamp}
                title={`${work.data.title} on Bandcamp`}
                style={`border: 0; width: 100%; height: ${work.data.bandcampHeight}px;`}
                loading="lazy"
                allow="autoplay"
              ></iframe>
            </div>
          </div>
        )}

        {work.data.exhibitions.length > 0 && (
          <div class="work-exhibition-block">
            <div class="work-exhibition-rule"></div>
            <p class="work-exhibition-inline">
              {work.data.exhibitions.map((ex, i) => (
                <span>
                  {i > 0 && '; '}
                  {ex.venue}, {ex.location}, {ex.year}{ex.note && ` (${ex.note})`}
                </span>
              ))}
            </p>
            {work.data.exhibitionDescription && (
              <p class="work-exhibition-description">{work.data.exhibitionDescription}</p>
            )}
          </div>
        )}
      </div>
    </div>
  </article>
</Base>
