  <script>
    // Spacebar: scroll to next section heading
    document.addEventListener('keydown', (e) => {
      if (e.code !== 'Space') return;
      if (!document.querySelector('.info-page')) return;
      // Don't hijack if user is typing in an input
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) return;
      e.preventDefault();

      const headings = [...document.querySelectorAll('.info-page > h2')];
      const scrollY = window.scrollY;
      const next = headings.find(h => h.offsetTop > scrollY + 10);
      if (next) {
        // Scroll so the top border is just above the viewport
        window.scrollTo({ top: next.offsetTop + 2, behavior: 'smooth' });
      } else {
        // Wrap to top
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  </script>

