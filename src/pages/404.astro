---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found"
  description="The page you're looking for doesn't exist."
  path="/404"
>
  <div class="notfound-page">
    {/* A flat 1px line across the page — the site's waveform at rest. It ripples under
        the cursor (or a tap) and springs back to silence; big swings overlap the text
        rather than clipping. Static under prefers-reduced-motion. */}
    <p class="notfound-text">Page not found</p>
    <canvas class="notfound-wave" aria-hidden="true"></canvas>
    <a href="/">View works</a>
  </div>

  <style>
    /* The whole block sits at the vertical middle of the viewport. */
    .notfound-page {
      min-height: calc(100vh - 6rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }
    .notfound-text {
      position: relative;
      z-index: 1;
      margin: 0;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    /* Tall canvas with negative margins: the resting line sits between the two texts,
       and a hard ripple has ~200px of headroom either way (the physics also clamps
       displacement to the canvas), so it rides OVER the words instead of clipping.
       z-index above the text, pointer-events off so the link stays clickable. */
    .notfound-wave {
      position: relative;
      z-index: 2;
      pointer-events: none;
      display: block;
      width: 100%;
      height: 480px;
      margin: -208px auto;
    }
  </style>

  <script>
    // String physics on a canvas line: pointer movement pushes displacement into the
    // nearest points; neighbor coupling spreads it as a ripple; spring + damping bring
    // it back to a flat line and the rAF loop stops itself.
    let ctrl: AbortController | null = null;
    let raf = 0;

    function init404() {
      ctrl?.abort();
      cancelAnimationFrame(raf);
      ctrl = null;
      const canvas = document.querySelector<HTMLCanvasElement>('.notfound-wave');
      const ctx = canvas?.getContext('2d');
      if (!canvas || !ctx) return;
      ctrl = new AbortController();
      const { signal } = ctrl;

      const DPR = Math.min(2, window.devicePixelRatio || 1);
      const N = 140;
      const pos = new Float32Array(N);
      const vel = new Float32Array(N);
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let running = false;

      const draw = () => {
        const w = canvas.width, h = canvas.height, mid = h / 2;
        ctx.clearRect(0, 0, w, h);
        ctx.beginPath();
        ctx.moveTo(0, mid + pos[0] * DPR);
        for (let i = 1; i < N; i++) ctx.lineTo((i / (N - 1)) * w, mid + pos[i] * DPR);
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.85)';
        ctx.lineWidth = DPR;
        ctx.lineCap = 'round';
        ctx.stroke();
      };

      const size = () => {
        canvas.width = canvas.clientWidth * DPR;
        canvas.height = canvas.clientHeight * DPR;
        draw();
      };

      const tick = () => {
        let energy = 0;
        const spring = 0.03, spread = 0.2, damp = 0.955;
        for (let i = 0; i < N; i++) {
          const left = i > 0 ? pos[i - 1] : 0;
          const right = i < N - 1 ? pos[i + 1] : 0;
          vel[i] += (left + right - 2 * pos[i]) * spread - pos[i] * spring;
          vel[i] *= damp;
        }
        // Keep the wildest swings inside the canvas — displacement is clamped a few
        // pixels shy of the edge so the line never renders cut off.
        const maxAmp = canvas.height / DPR / 2 - 4;
        for (let i = 0; i < N; i++) {
          pos[i] += vel[i];
          if (pos[i] > maxAmp) { pos[i] = maxAmp; vel[i] *= 0.5; }
          else if (pos[i] < -maxAmp) { pos[i] = -maxAmp; vel[i] *= 0.5; }
          energy += Math.abs(pos[i]) + Math.abs(vel[i]);
        }
        draw();
        // Threshold is a summed sub-pixel residue across all 140 points — snapping to
        // flat at this level is invisible, and guarantees the loop always ends.
        if (energy > 2.5) {
          raf = requestAnimationFrame(tick);
        } else {
          running = false;
          pos.fill(0);
          vel.fill(0);
          draw();
        }
      };

      const wake = () => {
        if (!running) {
          running = true;
          raf = requestAnimationFrame(tick);
        }
      };

      const poke = (clientX: number, strength: number) => {
        const r = canvas.getBoundingClientRect();
        const x = (clientX - r.left) / r.width;
        if (x < -0.05 || x > 1.05) return;
        const center = x * (N - 1);
        for (let i = 0; i < N; i++) {
          const d = (i - center) / 5;
          vel[i] += strength * Math.exp(-d * d);
        }
        wake();
      };

      if (!reduced) {
        let lastY: number | null = null;
        // The canvas is pointer-events: none (so the link under it stays clickable);
        // both interactions listen on window and gate on proximity to the line.
        const nearLine = (y: number) => {
          const r = canvas.getBoundingClientRect();
          const mid = r.top + r.height / 2;
          return Math.abs(y - mid) < 90;
        };
        window.addEventListener('pointermove', (e) => {
          if (nearLine(e.clientY)) {
            const dy = lastY === null ? 3 : e.clientY - lastY;
            poke(e.clientX, Math.max(-8, Math.min(8, dy * 1.1 || 1.5)));
          }
          lastY = e.clientY;
        }, { signal });
        window.addEventListener('pointerdown', (e) => {
          if (nearLine(e.clientY)) poke(e.clientX, 12);
        }, { signal });
      }
      window.addEventListener('resize', size, { signal });
      size();
    }
    document.addEventListener('astro:page-load', init404);
  </script>
</Base>
