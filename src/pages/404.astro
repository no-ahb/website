---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found"
  description="The page you're looking for doesn't exist."
  path="/404"
>
  <div class="info-page">
    <section class="info-section" style="border-bottom: none; text-align: center; padding-top: 20vh;">
      <p style="color: var(--color-meta); margin-bottom: 1.5rem;">Page not found.</p>
      <a href="/">View works</a>
    </section>
  </div>
</Base>
