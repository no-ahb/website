---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found"
  description="The page you're looking for doesn't exist."
  path="/404"
>
  <div class="notfound-page">
    {/* A flat 1px line — the site's waveform at rest. It ripples under the cursor
        (or a tap) and springs back to silence. Static under prefers-reduced-motion. */}
    <canvas class="notfound-wave" aria-hidden="true"></canvas>
    <p class="notfound-text">Page not found.</p>
    <a href="/">View works</a>
  </div>

  <style>
    .notfound-page {
      min-height: 60vh;
      padding-top: 18vh;
      text-align: center;
    }
    .notfound-wave {
      display: block;
      width: min(520px, 82%);
      height: 72px;
      margin: 0 auto 2.25rem;
      touch-action: none;
    }
    .notfound-text {
      color: var(--color-meta);
      margin-bottom: 1.5rem;
    }
  </style>

  <script>
    // String physics on a canvas line: pointer movement pushes displacement into the
    // nearest points; neighbor coupling spreads it as a ripple; spring + damping bring
    // it back to a flat line and the rAF loop stops itself.
    let ctrl: AbortController | null = null;
    let raf = 0;

    function init404() {
      ctrl?.abort();
      cancelAnimationFrame(raf);
      ctrl = null;
      const canvas = document.querySelector<HTMLCanvasElement>('.notfound-wave');
      const ctx = canvas?.getContext('2d');
      if (!canvas || !ctx) return;
      ctrl = new AbortController();
      const { signal } = ctrl;

      const DPR = Math.min(2, window.devicePixelRatio || 1);
      const N = 140;
      const pos = new Float32Array(N);
      const vel = new Float32Array(N);
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let running = false;

      const draw = () => {
        const w = canvas.width, h = canvas.height, mid = h / 2;
        ctx.clearRect(0, 0, w, h);
        ctx.beginPath();
        ctx.moveTo(0, mid + pos[0] * DPR);
        for (let i = 1; i < N; i++) ctx.lineTo((i / (N - 1)) * w, mid + pos[i] * DPR);
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.85)';
        ctx.lineWidth = DPR;
        ctx.lineCap = 'round';
        ctx.stroke();
      };

      const size = () => {
        canvas.width = canvas.clientWidth * DPR;
        canvas.height = canvas.clientHeight * DPR;
        draw();
      };

      const tick = () => {
        let energy = 0;
        const spring = 0.03, spread = 0.2, damp = 0.955;
        for (let i = 0; i < N; i++) {
          const left = i > 0 ? pos[i - 1] : 0;
          const right = i < N - 1 ? pos[i + 1] : 0;
          vel[i] += (left + right - 2 * pos[i]) * spread - pos[i] * spring;
          vel[i] *= damp;
        }
        for (let i = 0; i < N; i++) {
          pos[i] += vel[i];
          energy += Math.abs(pos[i]) + Math.abs(vel[i]);
        }
        draw();
        // Threshold is a summed sub-pixel residue across all 140 points — snapping to
        // flat at this level is invisible, and guarantees the loop always ends.
        if (energy > 2.5) {
          raf = requestAnimationFrame(tick);
        } else {
          running = false;
          pos.fill(0);
          vel.fill(0);
          draw();
        }
      };

      const wake = () => {
        if (!running) {
          running = true;
          raf = requestAnimationFrame(tick);
        }
      };

      const poke = (clientX: number, strength: number) => {
        const r = canvas.getBoundingClientRect();
        const x = (clientX - r.left) / r.width;
        if (x < -0.05 || x > 1.05) return;
        const center = x * (N - 1);
        for (let i = 0; i < N; i++) {
          const d = (i - center) / 5;
          vel[i] += strength * Math.exp(-d * d);
        }
        wake();
      };

      if (!reduced) {
        let lastY: number | null = null;
        window.addEventListener('pointermove', (e) => {
          const r = canvas.getBoundingClientRect();
          if (e.clientY > r.top - 48 && e.clientY < r.bottom + 48) {
            const dy = lastY === null ? 3 : e.clientY - lastY;
            poke(e.clientX, Math.max(-6, Math.min(6, dy * 0.9 || 1.5)));
          }
          lastY = e.clientY;
        }, { signal });
        canvas.addEventListener('pointerdown', (e) => poke(e.clientX, 9), { signal });
      }
      window.addEventListener('resize', size, { signal });
      size();
    }
    document.addEventListener('astro:page-load', init404);
  </script>
</Base>
