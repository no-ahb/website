---
interface Props {
  src: string;
  title: string;
  work?: string;
  clip?: string;
}

import { asset } from '../lib/asset';
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import { parseFile } from 'music-metadata';
import peaksMap from '../data/audio-peaks.json';

const { src, title, work, clip } = Astro.props;

// Waveform seekbar: pre-rendered peak envelope (scripts/generate-audio-peaks.mjs →
// src/data/audio-peaks.json). The seekbar draws the piece's own contour as a 1px ink
// outline; the played portion fills solid via a clip that tracks playback. Files
// without peaks fall back to the plain hairline.
const peaks: number[] | undefined = (peaksMap as Record<string, number[]>)[src];
let waveD = '';
if (peaks && peaks.length > 1) {
  const n = peaks.length;
  const X = (i: number) => +((i / (n - 1)) * 200).toFixed(1);
  const top = peaks.map((p, i) => `${X(i)},${(16 - p * 14).toFixed(1)}`).join(' L');
  const bot = peaks.map((p, i) => `${X(i)},${(16 + p * 14).toFixed(1)}`).reverse().join(' L');
  waveD = `M${top} L${bot} Z`;
}

function fmtDuration(secs: number): string {
  if (!isFinite(secs) || secs <= 0) return '0:00';
  const m = Math.floor(secs / 60);
  const s = Math.floor(secs % 60).toString().padStart(2, '0');
  return `${m}:${s}`;
}

let preDuration = '0:00';
try {
  const filePath = resolve('public', src.replace(/^\//, ''));
  if (existsSync(filePath)) {
    const { format } = await parseFile(filePath, { duration: true });
    if (format.duration) preDuration = fmtDuration(format.duration);
  }
} catch {}
---

<div class="audio-player" data-src={asset(src)} data-title={title} data-work={work || title} data-clip={clip} data-duration={preDuration}>
  <button class="audio-player-play" aria-label="Play">
    <svg class="icon-play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
      <polygon points="6 3 20 12 6 21 6 3" />
    </svg>
    <svg class="icon-pause" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
      <rect x="6" y="4" width="4" height="16" />
      <rect x="14" y="4" width="4" height="16" />
    </svg>
  </button>

  <div class="audio-player-track">
    {waveD ? (
      <svg class="ap-wave" viewBox="0 0 200 32" preserveAspectRatio="none" aria-hidden="true">
        <path class="ap-wave-bg" d={waveD} />
        <g class="ap-wave-clip" style="clip-path: inset(0 100% 0 0)">
          <path class="ap-wave-fg" d={waveD} />
        </g>
      </svg>
    ) : (
      <div class="audio-player-progress">
        <div class="audio-player-filled"></div>
      </div>
    )}
  </div>

  <span class="audio-player-time">0:00 / {preDuration}</span>
</div>

<style>
  .audio-player {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    width: 100%;
    margin: 0 auto;
    font-family: 'Instrument Sans', -apple-system, 'Helvetica Neue', sans-serif;
  }

  .audio-player-play {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 50%;
    background: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0, 0, 0, 0.75);
    transition: border-color 0.15s ease, color 0.15s ease;
    padding: 0;
  }
  .audio-player-play:hover {
    border-color: rgba(0, 0, 0, 0.4);
    color: rgba(0, 0, 0, 0.9);
  }

  .audio-player-play .icon-pause { display: none; }
  .audio-player.playing .audio-player-play .icon-play { display: none; }
  .audio-player.playing .audio-player-play .icon-pause { display: block; }

  .audio-player-track {
    flex: 1;
    min-width: 0;
    cursor: pointer;
    padding: 8px 0;
  }

  .audio-player-progress {
    width: 100%;
    height: 1px;
    background: rgba(0, 0, 0, 0.1);
    position: relative;
  }

  .audio-player-filled {
    height: 100%;
    background: rgba(0, 0, 0, 0.55);
    width: 0%;
    transition: width 0.1s linear;
  }

  .audio-player-track:hover .audio-player-progress {
    height: 2px;
  }

  /* Waveform seekbar — the piece's envelope as a hairline ink outline; the played
     portion is the same shape filled, revealed left-to-right by the clip. */
  .ap-wave {
    display: block;
    width: 100%;
    height: 26px;
  }
  .ap-wave-bg {
    fill: none;
    stroke: rgba(0, 0, 0, 0.22);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .ap-wave-fg {
    fill: rgba(0, 0, 0, 0.68);
    stroke: none;
  }
  .ap-wave-clip { transition: clip-path 0.1s linear; }

  .audio-player-time {
    flex-shrink: 0;
    font-size: 11px;
    color: rgba(0, 0, 0, 0.45);
    letter-spacing: 0.03em;
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  // Playback lives in the site-wide singleton (audio-manager.ts) so it survives
  // client-side navigation; this script only binds each rendered player's UI to it.
  // Re-runs on astro:page-load (fresh DOM every swap); the module-level nb:audio
  // subscription and rAF loop always paint the currently bound elements.
  import { nbAudio } from '../scripts/audio-manager';

  type Bound = {
    root: HTMLElement;
    playBtn: HTMLButtonElement;
    track: HTMLElement;
    filled: HTMLElement | null;
    clip: HTMLElement | null;
    timeEl: HTMLElement;
    preDur: string;
    meta: { src: string; title: string; work: string; clip?: string };
  };

  let bound: Bound[] = [];
  let raf = 0;

  function fmt(s: number): string {
    if (!isFinite(s)) return '0:00';
    return `${Math.floor(s / 60)}:${Math.floor(s % 60).toString().padStart(2, '0')}`;
  }

  const isCurrent = (b: Bound) => nbAudio.meta?.src === b.meta.src;

  function paint(b: Bound) {
    const a = nbAudio.el;
    const cur = isCurrent(b) && !!a;
    b.root.classList.toggle('playing', cur && nbAudio.playing);
    const dur = cur ? a!.duration || 0 : 0;
    const t = cur ? a!.currentTime || 0 : 0;
    const pct = dur ? (t / dur) * 100 : 0;
    if (b.filled) b.filled.style.width = `${pct}%`;
    if (b.clip) b.clip.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
    b.timeEl.textContent = cur && dur ? `${fmt(t)} / ${fmt(dur)}` : `0:00 / ${b.preDur}`;
  }

  function paintAll() {
    bound.forEach(paint);
    cancelAnimationFrame(raf);
    // Smooth fill while playing on this page; stops itself when playback stops.
    if (nbAudio.playing && bound.some(isCurrent)) {
      const loop = () => {
        bound.filter(isCurrent).forEach(paint);
        if (nbAudio.playing) raf = requestAnimationFrame(loop);
      };
      raf = requestAnimationFrame(loop);
    }
  }

  document.addEventListener('nb:audio', paintAll);

  document.addEventListener('astro:page-load', () => {
    bound = Array.from(document.querySelectorAll<HTMLElement>('.audio-player'))
      .filter((p) => p.dataset.src)
      .map((player) => {
        const b: Bound = {
          root: player,
          playBtn: player.querySelector('.audio-player-play') as HTMLButtonElement,
          track: player.querySelector('.audio-player-track') as HTMLElement,
          filled: player.querySelector('.audio-player-filled'),
          clip: player.querySelector('.ap-wave-clip'),
          timeEl: player.querySelector('.audio-player-time') as HTMLElement,
          preDur: player.dataset.duration || '0:00',
          meta: {
            src: player.dataset.src!,
            title: player.dataset.title || '',
            work: player.dataset.work || player.dataset.title || '',
            clip: player.dataset.clip || undefined,
          },
        };
        b.playBtn.addEventListener('click', () => {
          if (isCurrent(b)) nbAudio.toggle();
          else nbAudio.play(b.meta);
        });
        b.track.addEventListener('click', (e) => {
          const rect = b.track.getBoundingClientRect();
          const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
          if (isCurrent(b)) nbAudio.seekPct(pct);
          else nbAudio.play(b.meta);
        });
        return b;
      });
    paintAll();
  });
</script>
