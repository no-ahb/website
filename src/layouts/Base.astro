---
import Nav from '../components/Nav.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/main.css';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: string;
  showFooter?: boolean;
  noindex?: boolean;
}

const {
  title = 'Noah Berrie',
  description = 'Sound artist working between installation, composition, and performance.',
  path = Astro.url.pathname,
  image = '/images/homepage/hero.jpg',
  type = 'website',
  showFooter = false,
  noindex = false,
} = Astro.props;

const fullTitle = path === '/' ? 'Noah Berrie' : `${title} — Noah Berrie`;
const canonicalURL = new URL(path, Astro.site);
const metaDesc = description.length > 155 ? description.slice(0, description.lastIndexOf(' ', 155)) + '.' : description;
const ogImage = new URL(image, Astro.site);

const now = new Date();
const updated = now.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });

const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${base}info/`, label: 'Info' },
  { href: `${base}scoring/`, label: 'Scoring' },
  { href: base, label: 'Works' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="format-detection" content="telephone=no, date=no, email=no, address=no" />
  <title>{fullTitle}</title>
  <meta name="description" content={metaDesc} />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  {/* Client-side navigation + view transitions: pages swap without a full load, which is
      also what lets audio (audio-manager.ts) keep playing across navigation. Every script
      that binds to per-page DOM re-initializes on astro:page-load. */}
  <ClientRouter />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' data: https://cloud.umami.is; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' blob:; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://player.vimeo.com https://bandcamp.com https://*.bandcamp.com; connect-src 'self' https://cloud.umami.is https://gateway.umami.is" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;700&display=swap" rel="stylesheet" />

  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Noah Berrie" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={metaDesc} />
  <meta name="twitter:image" content={ogImage} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Noah Berrie",
    "url": Astro.site?.origin ?? "https://noahberrie.com",
    "sameAs": [
      "https://www.instagram.com/noahberrie/",
      "https://noahberrie.bandcamp.com",
    ],
    "jobTitle": "Sound Artist",
    "description": "Sound artist working between installation, composition, and performance.",
    "alumniOf": [
      { "@type": "CollegeOrUniversity", "name": "Stanford University", "department": "CCRMA" }
    ],
    "knowsAbout": ["sound art", "sound installation", "feedback systems", "electroacoustic music", "custom electronics", "instrument building", "multichannel audio", "self-oscillating strings"]
  }).replace(/</g, '\\u003c')} />

  <link rel="icon" id="favicon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <script defer src="https://cloud.umami.is/script.js" data-website-id="8d91b759-3a55-46f7-883c-1b36e6da9531"></script>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <div class="site-wrapper">
    <!-- Mobile: simple top bar with name + links -->
    <nav class="nav-mobile-bar" aria-label="Main navigation">
      <a href={base} class="mobile-name">Noah Berrie</a>
      <div class="mobile-links">
        {navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={(link.label === 'Works' && (path === '/' || path === base)) || (link.label === 'Info' && (path.startsWith('/info') || path.startsWith(`${base}info`))) || (link.label === 'Scoring' && (path.startsWith('/scoring') || path.startsWith(`${base}scoring`))) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>

    <!-- Desktop: fixed sidebar -->
    <Nav currentPath={path} />

    <main id="main-content" class="site-main">
      <slot />
      {showFooter && (
        <footer class="site-footer">
          <p>Last updated {updated}</p>
        </footer>
      )}
    </main>
  </div>

  <!-- Mini player — a small square, bottom right, that carries the playing piece when
       its inline player isn't on screen (scrolled away, or on another page entirely).
       Re-rendered per page like everything else; the audio itself lives in
       audio-manager.ts and keeps playing while pages swap. -->
  <div class="mini-player" id="mini-player" aria-hidden="true">
    <button class="mini-player-close" type="button" aria-label="Dismiss player">✕</button>
    <button class="mini-player-toggle" type="button" aria-label="Pause">
      <svg class="icon-play" width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
        <polygon points="6 3 20 12 6 21 6 3" />
      </svg>
      <svg class="icon-pause" width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
        <rect x="6" y="4" width="4" height="16" />
        <rect x="14" y="4" width="4" height="16" />
      </svg>
    </button>
    <a class="mini-player-title" href="/"></a>
    <svg class="mini-player-wave" viewBox="0 0 200 32" preserveAspectRatio="none" aria-hidden="true">
      <line class="mpw-axis" x1="0" y1="16" x2="200" y2="16" />
      <path class="mpw-bars" d="" />
      <line class="mpw-head" x1="0" y1="1" x2="0" y2="31" />
    </svg>
    <span class="mini-player-time">0:00</span>
  </div>

  <script>
    import { nbAudio } from '../scripts/audio-manager';

    // Mini-player binding. The square's DOM is replaced on every navigation, so elements
    // are re-queried and re-wired on astro:page-load; the single nb:audio subscription
    // below lives at module scope and always paints the current elements.
    const fmt = (s: number) => {
      if (!isFinite(s) || s <= 0) return '0:00';
      return `${Math.floor(s / 60)}:${Math.floor(s % 60).toString().padStart(2, '0')}`;
    };

    let mp: {
      root: HTMLElement; title: HTMLAnchorElement; toggle: HTMLButtonElement;
      close: HTMLButtonElement; wave: SVGSVGElement;
      bars: SVGPathElement; head: SVGLineElement;
      time: HTMLElement;
    } | null = null;
    let srcIO: IntersectionObserver | null = null;
    let srcVisible = false;

    // The inline player currently bound to the playing track, if it's on this page.
    function currentInlinePlayer(): HTMLElement | null {
      if (!nbAudio.meta) return null;
      return Array.from(document.querySelectorAll<HTMLElement>('.audio-player'))
        .find((p) => p.dataset.src === nbAudio.meta!.src) || null;
    }

    // Watch whether that inline player is on screen — the square only appears when the
    // piece is playing somewhere you can't see its controls.
    function watchSource() {
      srcIO?.disconnect();
      srcIO = null;
      srcVisible = false;
      const el = currentInlinePlayer();
      if (!el) { paint(); return; }
      srcIO = new IntersectionObserver((entries) => {
        entries.forEach((e) => { srcVisible = e.isIntersecting; });
        paint();
      }, { threshold: 0.35 });
      srcIO.observe(el);
    }

    function paint() {
      if (!mp) return;
      const a = nbAudio.el;
      const show = !!(nbAudio.meta && nbAudio.started && !nbAudio.ended && !srcVisible);
      mp.root.classList.toggle('is-shown', show);
      mp.root.setAttribute('aria-hidden', String(!show));
      if (!show || !a) return;
      const meta = nbAudio.meta!;
      mp.title.textContent = meta.title;
      mp.title.href = meta.href || '/';
      const d = meta.waveMini || '';
      if (mp.bars.getAttribute('d') !== d) mp.bars.setAttribute('d', d);
      mp.root.classList.toggle('is-playing', nbAudio.playing);
      mp.toggle.setAttribute('aria-label', nbAudio.playing ? 'Pause' : 'Play');
      const dur = a.duration || 0;
      const x = (dur ? (a.currentTime / dur) * 200 : 0).toFixed(2);
      mp.head.setAttribute('x1', x);
      mp.head.setAttribute('x2', x);
      mp.time.textContent = fmt(dur);
    }

    document.addEventListener('nb:audio', () => {
      // A new track may have started: re-resolve which inline player to watch.
      if (nbAudio.meta && mp && mp.root.dataset.watching !== nbAudio.meta.src) {
        mp.root.dataset.watching = nbAudio.meta.src;
        watchSource();
      }
      paint();
    });

    document.addEventListener('astro:page-load', () => {
      const root = document.getElementById('mini-player');
      if (!root) { mp = null; return; }
      mp = {
        root,
        title: root.querySelector('.mini-player-title') as HTMLAnchorElement,
        toggle: root.querySelector('.mini-player-toggle') as HTMLButtonElement,
        close: root.querySelector('.mini-player-close') as HTMLButtonElement,
        wave: root.querySelector('.mini-player-wave') as SVGSVGElement,
        bars: root.querySelector('.mpw-bars') as SVGPathElement,
        head: root.querySelector('.mpw-head') as SVGLineElement,
        time: root.querySelector('.mini-player-time') as HTMLElement,
      };
      if (nbAudio.meta) mp.root.dataset.watching = nbAudio.meta.src;
      mp.toggle.addEventListener('click', () => nbAudio.toggle());
      mp.close.addEventListener('click', () => nbAudio.stop());
      mp.wave.addEventListener('click', (e) => {
        const r = mp!.wave.getBoundingClientRect();
        nbAudio.seekPct((e.clientX - r.left) / r.width);
      });
      watchSource();
      paint();
    });
  </script>

  <script>
    // Horizontal gallery. The pan itself is a CSS scroll-driven animation (see main.css,
    // @supports animation-timeline) that runs on the compositor; non-supporting browsers
    // and mobile fall back to native horizontal scroll. JS only (a) sets --gallery-overflow
    // so the pinned wrapper's vertical scroll distance equals the horizontal travel, and
    // (b) updates the image counter.
    // Re-initialized on every client-side navigation: the elements are new after each
    // swap; the previous page's window listeners and observer tear down via the
    // AbortController/disconnect below.
    let galleryCtrl: AbortController | null = null;
    let galleryRO: ResizeObserver | null = null;

    function initGallery() {
      galleryCtrl?.abort();
      galleryRO?.disconnect();
      galleryCtrl = null;
      galleryRO = null;

      const wrap = document.querySelector<HTMLElement>('.work-scroll-wrap');
      const track = document.querySelector<HTMLElement>('.work-scroll-track');
      const gallery = document.querySelector<HTMLElement>('.work-scroll-gallery');
      if (!(wrap && track && gallery)) return;

      galleryCtrl = new AbortController();
      const { signal } = galleryCtrl;
      const imgs = [...track.querySelectorAll('img')];
      const counter = document.querySelector('.gallery-counter') as HTMLElement | null;

      const measure = () => {
        const overflow = Math.max(0, Math.round(track.scrollWidth - gallery.clientWidth));
        wrap.style.setProperty('--gallery-overflow', `${overflow}px`);
      };

      const updateCounter = () => {
        if (!counter || imgs.length <= 1) return;
        // Hide the counter once the gallery has scrolled out of view above — it lives in
        // the always-on-screen fixed sidebar and would otherwise linger on later sections.
        counter.style.display = wrap.getBoundingClientRect().bottom > 0 ? '' : 'none';
        const cx = gallery.getBoundingClientRect().left + gallery.clientWidth / 2;
        let current = 1;
        for (let i = 0; i < imgs.length; i++) {
          const r = imgs[i].getBoundingClientRect();
          if (r.left <= cx && r.right > cx) current = i + 1;
        }
        counter.textContent = `${current} / ${imgs.length}`;
      };

      galleryRO = new ResizeObserver(() => { measure(); updateCounter(); });
      galleryRO.observe(gallery);
      galleryRO.observe(track);
      imgs.forEach((img) => {
        if (!img.complete) img.addEventListener('load', () => { measure(); updateCounter(); }, { once: true, signal });
      });

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => { updateCounter(); ticking = false; });
      };
      window.addEventListener('scroll', onScroll, { passive: true, signal });   // pinned mode: page scroll pans the track
      gallery.addEventListener('scroll', onScroll, { passive: true, signal });  // native mode: gallery scrolls horizontally

      measure();
      updateCounter();
    }
    document.addEventListener('astro:page-load', initGallery);
  </script>
  <script>
    // Umami: track outbound link and mailto clicks
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement | null)?.closest?.('a');
      if (!link) return;
      const href = link.getAttribute('href') || '';
      if (!href) return;
      const umami = (window as any).umami;
      if (!umami?.track) return;
      if (href.startsWith('mailto:')) {
        umami.track('mailto-click');
        return;
      }
      if (/^https?:\/\//i.test(href)) {
        try {
          const url = new URL(href);
          if (url.hostname !== location.hostname) {
            umami.track('outbound-link', { url: href.slice(0, 200) });
          }
        } catch {}
      }
    }, { capture: true });
  </script>
  <script>
    // Animated favicon: line ↔ squiggle. Idle, it breathes through sine / triangle /
    // square on a slow 10s clock; while site audio plays (audio-manager.ts) the same
    // line becomes the LIVE waveform from the analyser tap — the tab icon hears the
    // piece — and relaxes back to the idle cycle when the sound stops.
    // The <link> is re-queried every tick: head merging during client-side navigation
    // can replace the element, which would strand a cached reference.
    let prevUrl: string | null = null;
    let liveBuf: Uint8Array | null = null;
    const update = () => {
      const faviconLink = document.getElementById('favicon') as HTMLLinkElement | null;
      if (!faviconLink) return;
      const t = Date.now();
      let d = 'M 3,16';

      const api = (window as any).__nbAudio;
      const analyser = api?.playing ? api.analyser : null;
      if (analyser) {
        // Live mode: five frequency-band bars bouncing with the sound (level meter,
        // Apple-Music style) — far more legible at 16×16 than a waveform trace.
        if (!liveBuf || liveBuf.length !== analyser.frequencyBinCount) liveBuf = new Uint8Array(analyser.frequencyBinCount);
        analyser.getByteFrequencyData(liveBuf);
        const bands = [[0, 4], [4, 10], [10, 24], [24, 52], [52, 110]];
        let rects = '';
        bands.forEach(([a0, a1], i) => {
          let sum = 0;
          for (let k = a0; k < a1; k++) sum += liveBuf![k];
          const v = Math.min(1, sum / (a1 - a0) / 190);
          const h = 4 + Math.pow(v, 1.2) * 25;
          rects += `<rect x="${(4.1 + i * 5.2).toFixed(1)}" y="${(16 - h / 2).toFixed(1)}" width="3.2" height="${h.toFixed(1)}" rx="1.6" fill="#111"/>`;
        });
        const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">${rects}</svg>`;
        if (prevUrl) URL.revokeObjectURL(prevUrl);
        const blob = new Blob([svg], { type: 'image/svg+xml' });
        prevUrl = URL.createObjectURL(blob);
        faviconLink.href = prevUrl;
        return;
      } else {
        // Idle mode: the original breathing cycle.
        // Waveform functions: sine, triangle, square
        const wave = [
          (p: number) => Math.sin(p),
          (p: number) => 2 * Math.abs(2 * (p / (Math.PI * 2) % 1) - 1) - 1,
          (p: number) => Math.sin(p) >= 0 ? 1 : -1,
        ];

        // Cycle waveform each breath (every 10s)
        const cycle = Math.floor(t / 10000) % 3;
        const fn = wave[cycle];

        // Cubic ease: lingers low, quick rise, lingers high, quick fall
        const phase = (t % 10000) / 10000;
        const half = phase < 0.5 ? phase * 2 : 2 - phase * 2;
        const ease = half * half * (3 - 2 * half);
        const amp = 0.3 + ease * 3.7;
        for (let i = 1; i <= 20; i++) {
          const x = 3 + i * 1.3;
          const y = 16 + fn(i * 0.9 + t / 400) * amp;
          d += ` L ${x.toFixed(1)},${y.toFixed(1)}`;
        }
      }

      const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
        <path d="${d}" stroke="#111" stroke-width="1.5" fill="none" stroke-linecap="round"/>
      </svg>`;

      if (prevUrl) URL.revokeObjectURL(prevUrl);
      const blob = new Blob([svg], { type: 'image/svg+xml' });
      prevUrl = URL.createObjectURL(blob);
      faviconLink.href = prevUrl;
    };
    setInterval(update, 150);
    update();
  </script>
</body>
</html>
